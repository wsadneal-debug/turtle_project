# ==================== 敏感配置 ====================
# 本地配置文件（可能包含 token、路径等）
config/*.local.json
config/*.local.yaml
config/*.local.yml
*.local.json
*.local.yaml
*.local.yml

# 环境变量文件
.env
.env.local
.env.*.local

# 凭证文件
*.pem
*.key
*.crt
credentials.json
credentials.yaml
secrets.json

# ==================== 输出数据 ====================
# 爬取结果（包含大量数据，不建议上传）
output/*.json
output/*.csv
data/*.json
data/*.csv

# 空目录占位符
!output/.gitkeep
!data/.gitkeep
!logs/.gitkeep

# 临时文件
*.tmp
*.bak
*.swp
*~

# ==================== 系统文件 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

