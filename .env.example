# ==================== 数据库配置 ====================
# 数据库文件路径（请使用绝对路径）
DB_PATH=/path/to/your/risk_stocks.db

# ==================== 日志配置 ====================
# 日志目录路径
LOG_DIR=/path/to/your/logs

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==================== 浏览器配置 ====================
# 浏览器 CDP 端口
BROWSER_CDP_PORT=18800

# 浏览器 Profile 名称
BROWSER_PROFILE=openclaw

# 浏览器用户数据目录
BROWSER_USER_DATA_DIR=/path/to/your/browser/data

# ==================== 通知配置（飞书） ====================
# 飞书 Webhook URL（替换为你的实际 token）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN

# 飞书群聊 ID（可选）
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxx

# ==================== 定时任务配置 ====================
# Cron 表达式（默认每天 18:00）
CRON_SCHEDULE=0 18 * * *

# 时区
TIMEZONE=Asia/Shanghai

# ==================== 搜索配置 ====================
# 搜索源列表（逗号分隔）
SEARCH_SOURCES=东方财富网，第一财经

# 搜索间隔（毫秒）
SEARCH_INTERVAL_MS=5000

# 最大爬取页数
MAX_PAGES=50

# ==================== 股票映射配置 ====================
# 最小映射置信度（0-100）
MIN_CONFIDENCE_SCORE=50

# 是否启用模糊匹配
ENABLE_FUZZY_MATCH=true

# ==================== 其他配置 ====================
# 是否启用调试模式
DEBUG=false

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 重试次数
MAX_RETRIES=3
